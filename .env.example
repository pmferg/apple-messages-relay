# messages-relay does NOT use .env files for secrets.
# All configuration is stored in:
#   ~/Library/Application Support/messages-relay/config.json
#
# This file exists only as a template/documentation.
# The install script (scripts/install.sh) creates config.json interactively.
#
# Example config.json structure:
#
# {
#   "mqtt": {
#     "broker": "ssl://broker.example.com:8883",
#     "topic": "personal/messages/send",
#     "username": "your-username",
#     "password": "your-password"
#   },
#   "security": {
#     "shared_secret": "your-long-random-secret",
#     "max_skew_seconds": 60,
#     "allowed_destinations": []
#   },
#   "limits": {
#     "max_per_minute": 5,
#     "max_per_day": 50
#   },
#   "relay": {
#     "applescript_path": "",
#     "test_mode": false
#   }
# }
